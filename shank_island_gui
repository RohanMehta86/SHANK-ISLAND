# ── Data files ───────────────────────────────────────────────────────────────
USERS_FILE    = "users.json"
ROUNDS_FILE   = "rounds.json"
FRIENDS_FILE  = "friends.json"    # {user: [friend,...]}
REQUESTS_FILE = "requests.json"   # {recipient: [sender,...]}
COMMENTS_FILE = "comments.json"   # {owner: {round_index: [{author,text}]}}
NOTIFS_FILE   = "notifs.json"     # {user: [{type,from,text,read}]}
 
def load_json(path):
    if os.path.exists(path):
        with open(path, "r") as f:
            return json.load(f)
    return {}
 
def save_json(path, data):
    with open(path, "w") as f:
        json.dump(data, f, indent=2)
 
def format_diff(diff):
    if diff == 0:  return "E (Even)"
    elif diff > 0: return f"+{diff} (over par)"
    else:          return f"{diff} (under par)"
 
def calc_handicap(rounds):
    diffs = []
    for r in rounds:
        try:
            diffs.append(int(r["score"]) - int(r["par"]))
        except (KeyError, ValueError):
            pass
    return sum(diffs) / len(diffs) if diffs else None
 
