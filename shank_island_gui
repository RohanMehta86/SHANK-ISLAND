    def show_leaderboard(self):
        self.geometry("500x580")
        self.clear()
        self.label(self.frame, "🏆  Leaderboard", size=20, bold=True, pady=10)
 
        # Tabs
        tab_var = tk.StringVar(value="handicap")
        tab_frame = tk.Frame(self.frame, bg="#1a5c2a"); tab_frame.pack()
 
        lf = tk.Frame(self.frame, bg="#1a5c2a"); lf.pack(pady=6)
        sb = tk.Scrollbar(lf); sb.pack(side="right", fill="y")
        lb = tk.Listbox(lf, font=("Courier", 11), width=48, height=11,
                        bg="#0f3d1a", fg="white", relief="flat",
                        yscrollcommand=sb.set, selectbackground="#2e8b57")
        sb.config(command=lb.yview); lb.pack(side="left")
 
        def refresh():
            lb.delete(0, "end")
            mode = tab_var.get()
            rows = []
 
            for user, user_rounds in self.rounds.items():
                if not user_rounds: continue
                hcp = calc_handicap(user_rounds)
                best_i, _ = get_best_worst(user_rounds)
                best_diff = None
                if best_i is not None:
                    try:
                        best_diff = int(user_rounds[best_i]["score"]) - int(user_rounds[best_i]["par"])
                    except (KeyError, ValueError):
                        pass
                rows.append((user, len(user_rounds), hcp, best_diff))
 
            if mode == "handicap":
                rows = [r for r in rows if r[2] is not None]
                rows.sort(key=lambda x: x[2])
                lb.insert("end", f"  {'#':<4}{'Player':<18}{'Handicap':<12}{'Rounds'}")
                lb.insert("end", f"  {'─'*44}")
                for rank, (user, cnt, hcp, _) in enumerate(rows, 1):
                    sign = "+" if hcp > 0 else ""
                    me = " ◀ YOU" if user == self.current_user else ""
                    medal = "🥇" if rank == 1 else ("🥈" if rank == 2 else ("🥉" if rank == 3 else f"  {rank}."))
                    lb.insert("end", f"  {medal:<5}{user:<18}{sign}{hcp:<10.1f}{cnt}{me}")
 
            elif mode == "rounds":
                rows.sort(key=lambda x: x[1], reverse=True)
                lb.insert("end", f"  {'#':<4}{'Player':<22}{'Rounds Played'}")
                lb.insert("end", f"  {'─'*44}")
                for rank, (user, cnt, hcp, _) in enumerate(rows, 1):
                    me = " ◀ YOU" if user == self.current_user else ""
                    medal = "🥇" if rank == 1 else ("🥈" if rank == 2 else ("🥉" if rank == 3 else f"  {rank}."))
                    lb.insert("end", f"  {medal:<5}{user:<22}{cnt}{me}")
 
            elif mode == "best":
                rows = [r for r in rows if r[3] is not None]
                rows.sort(key=lambda x: x[3])
                lb.insert("end", f"  {'#':<4}{'Player':<18}{'Best Round'}")
                lb.insert("end", f"  {'─'*44}")
                for rank, (user, cnt, hcp, best_diff) in enumerate(rows, 1):
                    sign = "+" if best_diff > 0 else ""
                    diff_str = "E" if best_diff == 0 else f"{sign}{best_diff}"
                    me = " ◀ YOU" if user == self.current_user else ""
                    medal = "🥇" if rank == 1 else ("🥈" if rank == 2 else ("🥉" if rank == 3 else f"  {rank}."))
                    lb.insert("end", f"  {medal:<5}{user:<18}{diff_str}{me}")
 
            if lb.size() <= 2:
                lb.insert("end", "  No data yet. Start logging rounds!")
 
        def make_tab(text, val):
            tk.Radiobutton(tab_frame, text=text, variable=tab_var, value=val,
                           font=("Georgia", 10, "bold"), bg="#1a5c2a", fg="#f0e68c",
                           selectcolor="#0f3d1a", activebackground="#1a5c2a",
                           indicatoron=0, width=14, pady=4,
                           cursor="hand2", command=refresh).pack(side="left", padx=2)
 
        make_tab("Best Handicap", "handicap")
        make_tab("Most Rounds",   "rounds")
        make_tab("Best Round",    "best")
 
        refresh()
        self.button(self.frame, "Back", lambda: [self.geometry("500x560"), self.show_menu()])
 
    # ── PROFILE PAGE ─────────────────────────────────────────────────────────
    def show_profile(self, username=None):
        viewing = username or self.current_user
        is_own  = (viewing == self.current_user)
        self.geometry("500x620")
        self.clear()
 
        self.label(self.frame, f"👤  {viewing}'s Profile", size=17, bold=True, pady=8)
 
        user_rounds = self.rounds.get(viewing, [])
        friends     = self.get_friends(viewing)
        handicap    = calc_handicap(user_rounds)
        best_i, worst_i = get_best_worst(user_rounds)
 
        # Stats box
        stats_frame = tk.Frame(self.frame, bg="#0f3d1a", padx=16, pady=12)
        stats_frame.pack(padx=24, pady=4, fill="x")
 
        def stat_row(label, value, color="white"):
            row = tk.Frame(stats_frame, bg="#0f3d1a"); row.pack(fill="x", pady=2)
            tk.Label(row, text=label, font=("Georgia", 11), bg="#0f3d1a",
                     fg="#aaaaaa", width=22, anchor="w").pack(side="left")
            tk.Label(row, text=value, font=("Georgia", 11, "bold"), bg="#0f3d1a",
                     fg=color, anchor="w").pack(side="left")
 
        stat_row("Rounds Played:", str(len(user_rounds)))
        stat_row("Friends:",       str(len(friends)))
 
        if handicap is not None:
            sign = "+" if handicap > 0 else ""
            hcp_color = "#ff6b6b" if handicap > 0 else "#7fffaa"
            stat_row("Handicap:", f"{sign}{handicap:.1f}", color=hcp_color)
        else:
            stat_row("Handicap:", "No rounds yet")
 
        if best_i is not None:
            br = user_rounds[best_i]
            try:
                bd = int(br["score"]) - int(br["par"])
                bd_str = format_diff(bd)
            except (KeyError, ValueError):
                bd_str = "N/A"
            stat_row("Best Round:", f"{br['course']} — {bd_str}", color="#f0e68c")
 
        if worst_i is not None:
            wr = user_rounds[worst_i]
            try:
                wd = int(wr["score"]) - int(wr["par"])
                wd_str = format_diff(wd)
            except (KeyError, ValueError):
                wd_str = "N/A"
            stat_row("Worst Round:", f"{wr['course']} — {wd_str}", color="#ff6b6b")
 
        # Favourite course (most played)
        if user_rounds:
            from collections import Counter
            course_counts = Counter(r.get("course", "") for r in user_rounds)
            fav = course_counts.most_common(1)[0]
            stat_row("Favourite Course:", f"{fav[0]} ({fav[1]}x)")
 
            # Average score vs par
            diffs = []
            for r in user_rounds:
                try: diffs.append(int(r["score"]) - int(r["par"]))
                except (KeyError, ValueError): pass
            if diffs:
                avg = sum(diffs) / len(diffs)
                sign = "+" if avg > 0 else ""
                stat_row("Avg Score vs Par:", f"{sign}{avg:.1f}")
 
        # Recent rounds mini-list
        if user_rounds:
            self.label(self.frame, "Recent Rounds", size=12, bold=True, pady=4)
            recent_frame = tk.Frame(self.frame, bg="#0f3d1a", padx=8, pady=6)
            recent_frame.pack(padx=24, fill="x")
            for r in reversed(user_rounds[-5:]):
                try:
                    diff = int(r["score"]) - int(r["par"])
                    diff_str = format_diff(diff)
                except (KeyError, ValueError):
                    diff_str = "N/A"
                tk.Label(recent_frame,
                         text=f"  {r.get('course','?')}  —  {r.get('score','?')}/{r.get('par','?')} ({diff_str})",
                         font=("Courier", 9), bg="#0f3d1a", fg="white", anchor="w").pack(fill="x")
 
        self.button(self.frame, "Back", lambda: [self.geometry("500x560"), self.show_menu()])
 
