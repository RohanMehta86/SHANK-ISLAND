    # LOGIN
    def show_login(self):
        self.geometry("500x500")
        self.clear()
        self.label(self.frame, "Login", size=20, bold=True, pady=20)
        self.label(self.frame, "Username:", size=11)
        username_entry = self.entry(self.frame)
        self.label(self.frame, "Password:", size=11)
        password_entry = self.entry(self.frame, show="*")
 
        def attempt_login():
            u = username_entry.get().strip()
            p = password_entry.get().strip()
            if not u or not p:
                messagebox.showwarning("Missing info", "Please enter a username and password.")
                return
            if u in self.users:
                if self.users[u] == p:
                    self.current_user = u
                    self.show_menu()
                else:
                    messagebox.showerror("Wrong password", "Incorrect password. Please try again.")
            else:
                self.show_new_user_prompt(u, p)
 
        self.button(self.frame, "Login", attempt_login)
 
