def get_tip_of_the_day():
    import datetime
    day_of_year = datetime.date.today().timetuple().tm_yday
    return GOLF_TIPS[day_of_year % len(GOLF_TIPS)]
 
def get_best_worst(rounds):
    """Return (best_index, worst_index) by score-par diff. None if <1 valid round."""
    scored = []
    for i, r in enumerate(rounds):
        try:
            scored.append((i, int(r["score"]) - int(r["par"])))
        except (KeyError, ValueError):
            pass
    if not scored:
        return None, None
    best  = min(scored, key=lambda x: x[1])[0]
    worst = max(scored, key=lambda x: x[1])[0]
    return best, worst
 
# ── App ───────────────────────────────────────────────────────────────────────
class ShankIslandApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Shank Island")
        self.geometry("500x500")
        self.resizable(False, False)
        self.configure(bg="#1a5c2a")
 
        self.current_user = None
        self.users    = load_json(USERS_FILE)
        self.rounds   = load_json(ROUNDS_FILE)
        self.friends  = load_json(FRIENDS_FILE)
        self.requests = load_json(REQUESTS_FILE)
        self.comments = load_json(COMMENTS_FILE)
        self.notifs   = load_json(NOTIFS_FILE)
 
        self.frame = None
        self.show_home()
 
    # ── helpers ───────────────────────────────────────────────────────────────
    def clear(self):
        if self.frame:
            self.frame.destroy()
        self.frame = tk.Frame(self, bg="#1a5c2a")
        self.frame.pack(expand=True, fill="both")
 
    def label(self, parent, text, size=14, bold=False, color="white", pady=5):
        weight = "bold" if bold else "normal"
        tk.Label(parent, text=text, font=("Georgia", size, weight),
                 bg="#1a5c2a", fg=color).pack(pady=pady)
 
    def button(self, parent, text, command, width=20):
        tk.Button(parent, text=text, command=command,
                  font=("Georgia", 12), width=width,
                  bg="#f0e68c", fg="#1a5c2a", relief="raised",
                  cursor="hand2").pack(pady=5)
 
    def entry(self, parent, show=None, width=30):
        e = tk.Entry(parent, font=("Georgia", 12), width=width, show=show)
        e.pack(pady=4)
        return e
 
    def get_friends(self, user):
        return self.friends.get(user, [])
 
    def get_requests(self, user):
        return self.requests.get(user, [])
 
    def add_notif(self, recipient, notif_type, from_user, text):
        """Push a notification to a user."""
        self.notifs.setdefault(recipient, [])
        self.notifs[recipient].append({
            "type": notif_type, "from": from_user,
            "text": text, "read": False
        })
        save_json(NOTIFS_FILE, self.notifs)
 
    def unread_notif_count(self):
        return sum(1 for n in self.notifs.get(self.current_user, []) if not n["read"])
 
    def get_round_comments(self, owner, round_idx):
        return self.comments.get(owner, {}).get(str(round_idx), [])
 
    def add_comment(self, owner, round_idx, author, text):
        self.comments.setdefault(owner, {})
        key = str(round_idx)
        self.comments[owner].setdefault(key, [])
        self.comments[owner][key].append({"author": author, "text": text})
        save_json(COMMENTS_FILE, self.comments)
 
    # ── top bar helper ────────────────────────────────────────────────────────
    def _make_top_bar(self):
        top_bar = tk.Frame(self.frame, bg="#1a5c2a")
        top_bar.pack(fill="x", padx=8, pady=(6, 0))
 
        # Friends icon
        tk.Button(top_bar, text="👤", command=self.show_friends_list,
                  font=("Georgia", 14), bg="#1a5c2a", fg="#f0e68c",
                  relief="flat", cursor="hand2", bd=0).pack(side="right", padx=(4, 0))
 
        # Envelope icon with unread badge
        unread = self.unread_notif_count()
        env_text = f"✉ {unread}" if unread else "✉"
        env_color = "#e67e22" if unread else "#f0e68c"
        tk.Button(top_bar, text=env_text, command=self.show_notifications,
                  font=("Georgia", 13), bg="#1a5c2a", fg=env_color,
                  relief="flat", cursor="hand2", bd=0).pack(side="right", padx=(4, 0))
 
