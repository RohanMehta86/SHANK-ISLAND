    # ── NOTIFICATIONS ─────────────────────────────────────────────────────────
    def show_notifications(self):
        self.geometry("500x500")
        self.clear()
        self.label(self.frame, "✉  Notifications", size=18, bold=True, pady=10)
 
        user_notifs = self.notifs.get(self.current_user, [])
 
