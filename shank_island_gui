        self.clear()
        self.label(self.frame, "Username not found.", size=13, pady=30)
        self.label(self.frame, "Are you creating a new account?", size=12)
 
        def yes():
            self.users[username] = password
            save_json(USERS_FILE, self.users)
            self.current_user = username
            self.show_menu()
 
        self.button(self.frame, "Yes", yes)
        self.button(self.frame, "No", self.show_login)
 
