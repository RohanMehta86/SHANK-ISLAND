            f"  Rating : {r['rating']}/10\n"
            f"  Player : {owner}\n"
        )
        info.config(state="disabled")
 
        self.label(self.frame, "💬 Comments", size=13, bold=True, pady=4)
 
        comments = self.get_round_comments(owner, round_idx)
        cbox = tk.Text(self.frame, font=("Courier", 10), width=50, height=5,
                       bg="#0f3d1a", fg="white", relief="flat", padx=8, pady=4)
        cbox.pack()
        if not comments:
            cbox.insert("end", "  No comments yet. Be the first!\n")
        else:
            for c in comments:
